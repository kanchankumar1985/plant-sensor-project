# Storage Paths
# Leave empty to use default (backend/images and backend/videos)
# Set to external drive path to save laptop space
# Example: /Volumes/SD-128GB/PlantMonitor
IMAGES_DIR=
VIDEOS_DIR=
LOGS_DIR=/Volumes/SD-128GB/PlantMonitor/logs

# Camera Settings for Webcam Capture
# Adjust these values to control image brightness and exposure

# Auto Exposure Mode: 1=manual, 3=auto
CAMERA_AUTO_EXPOSURE=1

# Exposure Level: -13 (darkest) to -1 (brightest)
# Lower values = darker images, higher values = brighter images
# Try -8 or -10 if images are too bright, -4 or -3 if too dark
CAMERA_EXPOSURE=-6

# Brightness: 0 (darkest) to 255 (brightest)
CAMERA_BRIGHTNESS=128

# Contrast: 0 (lowest) to 100 (highest)
CAMERA_CONTRAST=32

# Camera Warmup Time (seconds): Time to wait after setting properties
CAMERA_WARMUP_TIME=0.5

# Temperature Alert Settings
# Minimum interval (seconds) between automatic snapshots when temp >= threshold
SNAPSHOT_COOLDOWN=60

# Image Compression Settings
# JPEG quality: 0 (worst/smallest) to 100 (best/largest)
# Recommended: 85 for good quality with ~50% size reduction
IMAGE_JPEG_QUALITY=85

# Video Alert Settings
# Enable video recording when temperature alert is triggered
VIDEO_ALERT_ENABLED=true

# Video duration in seconds (how long to record)
VIDEO_ALERT_DURATION=5

# Video FPS (frames per second) - 20-30 recommended for smooth playback
VIDEO_ALERT_FPS=25

# Video codec: XVID (best compatibility), MP4V (good), MJPG (large files)
VIDEO_ALERT_CODEC=XVID

# Video file extension (.avi or .mp4)
VIDEO_ALERT_EXTENSION=.avi
